# ml-project/MLproject

name: FAE_Hybrid_Forecasting

conda_env: python_env.yaml

entry_points:
  main:
    parameters:
      # Key parameters for reproducibility and model selection
      model_name: {type: str, default: "Euclidean FAE", description: "Which FAE variant to run"}
      latent_dim: {type: int, default: 150}
      epochs: {type: int, default: 10}
      batch_size: {type: int, default: 32}
      learning_rate: {type: float, default: 0.001}
      lambda_ortho: {type: float, default: 0.0001, description: "Only used by Hyperbolic FAE"}
    command: "python src/main.py --model_name {model_name} --latent_dim {latent_dim} --epochs {epochs} --batch_size {batch_size} --learning_rate {learning_rate} --lambda_ortho {lambda_ortho}"